# ============================================
# Server Environment Configuration Example
# Copy this file to .env.local and modify as needed
# ============================================

# Server binding
# HOST=127.0.0.1    # Default: bind to localhost only (secure)
# HOST=0.0.0.0      # Bind to all interfaces (needed for external access)
# HOST=localhost    # Use localhost (helps with VS Code port forwarding Cookie issues)
PORT=3000

# MongoDB connection
MONGO_DBNAME=myblog
MONGO_USERNAME=your_username
MONGO_PASSWORD=your_password
# MONGO_AUTH_SOURCE=myblog

# JWT Secret (generate a random string)
JWT_SECRET=your-jwt-secret-key

# Development CORS Origins (comma-separated for complex dev setups)
# DEV_CORS_ORIGINS=http://192.168.1.100:3001,http://localhost:3001

# Storage configuration
# UPLOAD_DIR=uploads
