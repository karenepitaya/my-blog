# ============================================
# Admin Frontend Environment Configuration Example
# Copy this file to .env.local and modify as needed
# ============================================

# API Proxy Target
# Default: http://localhost:3000
# Change this if your backend is on a different machine/IP
# VITE_API_PROXY_TARGET=http://192.168.1.100:3000

# API Base URL
# Use '/api' to leverage Vite proxy (recommended for development)
# VITE_API_BASE_URL=/api

# Font Configuration
# VITE_FONT_CSS_ZH=/fonts/current/noto-sans-sc/fonts.css
# VITE_FONT_ORIGIN=

# Optional: Gemini API key for AI assistant
# VITE_GEMINI_API_KEY=
